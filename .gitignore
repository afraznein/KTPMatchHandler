# into this PUBLIC repo. Keep one-off server tooling local. Tests are unaffected.
# Deliberate exception: git add -f scripts/<name>.py after a credential check.
scripts/*.py

# Compiled plugins belong in the gitignored compiled/ dir, never the repo root.
/*.amxx
